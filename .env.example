# Provided by Vercel + Neon integration in production.
# For local dev, copy to .env.local and fill in.
# Get values from: Vercel dashboard -> wings-web -> Settings -> Environment Variables.

DATABASE_URL=postgres://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL_UNPOOLED=postgres://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require

# Single shared secret for the host writer. Generate with: openssl rand -hex 32
WINGS_WEB_API_KEY=replace-me-with-a-strong-random-string
